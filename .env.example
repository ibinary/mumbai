# Server
PORT=3001
HOST=::
LOG_LEVEL=warn
# Set to 'production' on live deployments -- enables HSTS, tightens cookies, etc.
NODE_ENV=development

# PeerJS signaling runs standalone, bound to localhost. nginx must proxy
# PEER_PATH to PEER_HOST:PEER_PORT. Do NOT expose PEER_PORT publicly.
PEER_PATH=/mumbai
PEER_PORT=9000
PEER_HOST=127.0.0.1

# Set to true when running behind a reverse proxy (nginx, Cloudflare, etc.).
# Controls how the PeerJS server reads X-Forwarded-* headers.
TRUST_PROXY=true
