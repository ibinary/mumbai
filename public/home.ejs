<!DOCTYPE html>
<html lang="en">
    <head>
        <%- include('./header.ejs') %>
    </head>
    <body>
        <main class="home">
            <section class="home-card" role="region" aria-labelledby="home-title">
                <h1 id="home-title" class="home-title">
                    <img src="/assets/favicon.png" alt="" aria-hidden="true" />
                    Project Mumbai
                </h1>
                <p class="home-subtitle">Private, one-to-one video calls. No accounts. No logs.</p>

                <form id="home-form" class="home-form" autocomplete="off">
                    <label for="room-id" class="visually-hidden">Room name</label>
                    <input id="room-id" name="room-id" type="text" placeholder="Choose a room name" required maxlength="32" pattern="[A-Za-z0-9_-]{1,32}" autocomplete="off" />

                    <button id="create-room" class="btn btn--primary" type="submit">
                        <i class="fa-solid fa-circle-plus" aria-hidden="true"></i>
                        <span>Create Room</span>
                    </button>
                </form>
            </section>
        </main>

        <div id="toast-root" aria-live="polite" aria-atomic="true"></div>

        <script src="/assets/js/toast.js"></script>
        <script src="/assets/js/home.js"></script>
    </body>
</html>
